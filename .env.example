# AI Agent Company Swarm Configuration
# =====================================
# The swarm uses TWO models:
#   - WORKER model (DeepSeek) runs the 50 specialist agents.
#   - SUPERVISOR model (Claude) runs the executive roles (CEO/CTO/COO/CPO)
#     and every review gate.

# ---- WORKER MODEL: the specialist agents ----
# Provider: 'deepseek' | 'openai' | 'custom'
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_API_KEY=your_api_key_here            # generic fallback (e.g. 'custom')
# LLM_BASE_URL=https://your-openai-compatible-endpoint/v1   # required for 'custom'

# Worker model id. Set to the EXACT id your provider expects (a wrong id 404s).
# DeepSeek known-valid ids: deepseek-chat, deepseek-reasoner.
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3

# ---- SUPERVISOR MODEL: executive roles + review gates ----
# 'anthropic' (Claude, default when ANTHROPIC_API_KEY is set) or 'deepseek'
# (reuse the worker model, so the swarm runs on a single key).
SUPERVISOR_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SUPERVISOR_MODEL=claude-sonnet-4-6
SUPERVISOR_MAX_TOKENS=8192
# Claude adaptive thinking for sharper executive/gate decisions (true|false).
SUPERVISOR_THINKING=true

# ---- Swarm Settings ----
# auto = LLM supervisor runs unattended; interactive = human answers each prompt.
SWARM_MODE=auto
# Founder vision seed for 'auto' mode (or create founder-brief.md at the root).
# FOUNDER_BRIEF=Build a single-admin SaaS that turns a product brief into AI marketing videos...
SWARM_VERBOSE=true
